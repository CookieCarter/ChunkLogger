{
	"schemaVersion": 1,
	"id": "chunklogger",
	"version": "${version}",
	"name": "ChunkLogger",
	"description": "A simple mod which will log bedrock in the Nether to a file. Meant to be used in conjunction with a bedrock seed cracker.\n /logbedrock",
	"authors": [
		"CookieCarter"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/chunklogger/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"cookie.chunklogger.ChunkLogger"
		],
		"client": [
			"cookie.chunklogger.client.ChunkLoggerClient"
		]
	},
	"mixins": [
		"chunklogger.mixins.json",
		{
			"config": "chunklogger.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}